# Production dev-tools gate — visit https://yoursite.com/?devtools=THIS_VALUE once per tab
# Unlocks /dev, /admin, skip-sim, and unlimited respins. Leave empty to disable entirely.
VITE_DEV_GATE_KEY=change-me-before-deploy

# Re-spins per game for public players (default 3)
VITE_RESPINS_PER_RUN=3

# Google Analytics 4 (free) — Measurement ID from GA4 Admin → Data streams (e.g. G-XXXXXXXXXX)
VITE_GA_MEASUREMENT_ID=

# Set to true to send analytics events from local npm run dev
# VITE_ANALYTICS_IN_DEV=false

# Web3Forms — https://web3forms.com (Dashboard → Access Key)
VITE_WEB3FORMS_ACCESS_KEY=

# Optional mailto fallback on /feedback when Web3Forms is not configured
# VITE_FEEDBACK_EMAIL=you@example.com
